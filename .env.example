# ClosedClam Configuration
# Copy to .env and fill in your values

# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=

# Allowed Telegram user IDs (comma-separated, required for security)
TELEGRAM_ALLOWED_USERS=

# Anthropic API Key (fallback if OAuth not configured)
ANTHROPIC_API_KEY=

# DeepSeek API Key (optional, for deep research)
DEEPSEEK_API_KEY=

# Google AI API Key (optional, for image generation)
GOOGLE_AI_API_KEY=

# Brave Search API Key (optional, for web search)
BRAVE_API_KEY=

# OAuth callback port (default: 8976)
OAUTH_CALLBACK_PORT=8976

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Workspace root (default: current directory)
WORKSPACE_ROOT=
